# ── Database ──────────────────────────────────────────────────
# PostgreSQL (Railway production)
DATABASE_URL=postgresql://user:password@host:port/dbname

# SQLite (local dev - used automatically if DATABASE_URL not set)
DB_PATH=./jobstream.db

# ── Security ──────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-32-char-secret-key-here

# ── Email (Resend) ────────────────────────────────────────────
# Get from: resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
FROM_EMAIL=onboarding@resend.dev

# ── App URL ───────────────────────────────────────────────────
# Local dev
APP_URL=http://localhost:3000
# Production (update after Railway deployment)
# APP_URL=https://your-frontend.up.railway.app

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Payments (Paystack) ───────────────────────────────────────
# Get from: dashboard.paystack.com → Settings → API Keys
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxx
# Paystack plan codes (create plans in Paystack dashboard first)
PAYSTACK_PLAN_CANDIDATE_PREMIUM=PLN_xxxxxxxx
PAYSTACK_PLAN_EMPLOYER_STARTER=PLN_xxxxxxxx
PAYSTACK_PLAN_EMPLOYER_GROWTH=PLN_xxxxxxxx

# ── AI (Anthropic) ────────────────────────────────────────────
# Get from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
